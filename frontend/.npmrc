# react-dom is not a dependency of this app — it arrives transitively via
# expo-router -> vaul -> @radix-ui/*, which declare it as a peer. npm resolves
# that peer to a react-dom whose own peer wants a newer react than the one
# Expo SDK 57 pins us to, so a plain `npm install` fails with ERESOLVE.
#
# Nothing native ever loads react-dom (there is no web target: neither react-dom
# nor react-native-web is a dependency), so the conflict is noise. Accept it
# here instead of making every `npm install` need --legacy-peer-deps.
legacy-peer-deps=true
